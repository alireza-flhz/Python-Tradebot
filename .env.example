# Copy this file to .env and fill in your own values. .env is gitignored --
# never commit real credentials.

# From @BotFather on Telegram: /newbot -> gives you a token like
# 123456789:AAExampleTokenDoNotCommitThis
TELEGRAM_BOT_TOKEN=

# The chat the bot should post alerts to. For a DM to yourself: message
# @userinfobot (or your new bot) once, then read the chat id from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_CHAT_ID=
