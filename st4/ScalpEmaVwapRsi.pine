//@version=5
// =============================================================================
// Strategy Four (st4) - Scalp entry signal (simple)
// TradingView Pine Script v5  -  INDICATOR (arrows only)
//
// Only one job for now: mark the entry points.
//   * GREEN arrow (below the bar) = LONG entry
//   * RED   arrow (above the bar) = SHORT entry
//
// The signal is an EMA cross (fast over/under slow) - simple and it fires often,
// so you actually see arrows. An optional higher-timeframe trend filter is
// available but OFF by default.
//
// How to run:
//   1. TradingView -> Pine Editor -> paste this file -> Add to chart.
//   2. Works on any timeframe (built for 1m / 5m / 30m scalping).
// =============================================================================

indicator(
     title      = "st4 - Scalp S/R + FVG",
     shorttitle = "st4 S/R+FVG",
     overlay    = true)

// -----------------------------------------------------------------------------
// Inputs
// -----------------------------------------------------------------------------
fastLen = input.int(9,  "EMA Fast", minval = 1, group = "Signal")
slowLen = input.int(21, "EMA Slow", minval = 1, group = "Signal")

useBias = input.bool(false, "Only trade with higher-TF trend", group = "Trend filter (optional)")
biasTF  = input.timeframe("30", "Trend timeframe", group = "Trend filter (optional)")
biasLen = input.int(200, "Trend EMA length", minval = 1, group = "Trend filter (optional)")

// -----------------------------------------------------------------------------
// Signal
// -----------------------------------------------------------------------------
emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)

htfEma = request.security(syminfo.tickerid, biasTF, ta.ema(close, biasLen),
     lookahead = barmerge.lookahead_off)
biasUp = not useBias or close > htfEma
biasDn = not useBias or close < htfEma

longEntry  = ta.crossover(emaFast, emaSlow)  and biasUp   // LONG  -> green arrow
shortEntry = ta.crossunder(emaFast, emaSlow) and biasDn   // SHORT -> red arrow

// -----------------------------------------------------------------------------
// Plot (arrows only)
// -----------------------------------------------------------------------------
plotshape(longEntry,  title = "Long Entry",  style = shape.triangleup,
     location = location.belowbar, color = color.new(color.green, 0),
     size = size.small)
plotshape(shortEntry, title = "Short Entry", style = shape.triangledown,
     location = location.abovebar, color = color.new(color.red, 0),
     size = size.small)

// -----------------------------------------------------------------------------
// Alerts
// -----------------------------------------------------------------------------
alertcondition(longEntry,  title = "st4 Long Entry",  message = "st4 LONG on {{ticker}} {{interval}}")
alertcondition(shortEntry, title = "st4 Short Entry", message = "st4 SHORT on {{ticker}} {{interval}}")
