//@version=5
// =============================================================================
// Strategy Four (st4) - Scalp entry + Price Action + Trend Channel
// TradingView Pine Script v5  -  INDICATOR
//
// On the chart:
//   * TREND CHANNEL (linear regression): mid line + upper/lower bands.        <- NEW
//     Coloured GREEN when the slope points up, RED when it points down.
//   * TREND label (UP / DOWN) so you trade mostly WITH the trend.             <- NEW
//   * GREEN arrow (below bar) = LONG entry | RED arrow (above bar) = SHORT.
//     With "align to trend" ON, longs only show in an up-trend and shorts
//     only in a down-trend.
//   * Support / Resistance levels (swing pivots).
//   * Candlestick patterns: Engulfing (BuEng/BeEng), Hammer/Pin, Shooting Star.
//
// How to run:
//   1. TradingView -> Pine Editor -> paste this file -> Add to chart.
//   2. Works on any timeframe (built for 1m / 5m / 30m scalping).
// =============================================================================

indicator(
     title            = "st4 - Scalp S/R + FVG",
     shorttitle       = "st4 S/R+FVG",
     overlay          = true,
     max_lines_count  = 100,
     max_labels_count = 300)

// -----------------------------------------------------------------------------
// Inputs
// -----------------------------------------------------------------------------
// Entry signal (EMA cross)
fastLen    = input.int(9,  "EMA Fast", minval = 1, group = "Entry signal")
slowLen    = input.int(21, "EMA Slow", minval = 1, group = "Entry signal")
alignTrend = input.bool(true, "Only signal WITH the trend", group = "Entry signal")
useBias    = input.bool(false, "Also require higher-TF trend", group = "Entry signal")
biasTF     = input.timeframe("30", "Higher-TF timeframe", group = "Entry signal")
biasLen    = input.int(200, "Higher-TF EMA length", minval = 1, group = "Entry signal")

// Trend channel (linear regression)
showChan   = input.bool(true, "Show trend channel", group = "Trend Channel")
regLen     = input.int(100, "Channel length (bars)", minval = 5, group = "Trend Channel")
devMult    = input.float(2.0, "Channel width (xStdev)", minval = 0.5, step = 0.5, group = "Trend Channel")
showTrend  = input.bool(true, "Show TREND label", group = "Trend Channel")

// Price action - Support / Resistance
showSR     = input.bool(true, "Show Support/Resistance", group = "Price Action")
srLen      = input.int(10, "S/R pivot lookback", minval = 2, group = "Price Action")
srMax      = input.int(4,  "Levels per side", minval = 1, group = "Price Action")

// Price action - candlestick patterns
showPat    = input.bool(true, "Show candlestick patterns", group = "Price Action")
pinRatio   = input.float(2.0, "Pin/Hammer wick ratio", minval = 1.0, step = 0.5, group = "Price Action")

resCol     = input.color(color.red,   "Resistance", group = "Colors")
supCol     = input.color(color.green, "Support",    group = "Colors")

// -----------------------------------------------------------------------------
// Trend channel + direction (linear regression)
// -----------------------------------------------------------------------------
reg    = ta.linreg(close, regLen, 0)      // regression value at current bar
reg1   = ta.linreg(close, regLen, 1)      // regression value one bar ago
slope  = reg - reg1                        // per-bar slope -> trend direction
startP = reg - slope * (regLen - 1)        // regression value at start of window
endP   = reg
dev    = ta.stdev(close, regLen) * devMult

trendUp = slope > 0
trendDn = slope < 0

var line cMid = na
var line cUp  = na
var line cLo  = na
if showChan and barstate.islast
    if not na(cMid)
        line.delete(cMid)
        line.delete(cUp)
        line.delete(cLo)
    x1   = bar_index - regLen + 1
    tcol = trendUp ? color.green : color.red
    cMid := line.new(x1, startP,       bar_index, endP,       color = color.new(tcol, 0),  width = 2)
    cUp  := line.new(x1, startP + dev, bar_index, endP + dev, color = color.new(tcol, 40), style = line.style_dashed)
    cLo  := line.new(x1, startP - dev, bar_index, endP - dev, color = color.new(tcol, 40), style = line.style_dashed)

var label tLbl = na
if showTrend and barstate.islast
    if not na(tLbl)
        label.delete(tLbl)
    tcol = trendUp ? color.green : color.red
    ttxt = trendUp ? "TREND ▲ UP" : "TREND ▼ DOWN"
    tLbl := label.new(bar_index, high, ttxt, style = label.style_label_down,
         color = color.new(tcol, 0), textcolor = color.white, size = size.normal)

// -----------------------------------------------------------------------------
// Entry signal
// -----------------------------------------------------------------------------
emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)

htfEma = request.security(syminfo.tickerid, biasTF, ta.ema(close, biasLen),
     lookahead = barmerge.lookahead_off)
biasUp = not useBias or close > htfEma
biasDn = not useBias or close < htfEma

longEntry  = ta.crossover(emaFast, emaSlow)  and biasUp and (not alignTrend or trendUp)
shortEntry = ta.crossunder(emaFast, emaSlow) and biasDn and (not alignTrend or trendDn)

plotshape(longEntry,  title = "Long Entry",  style = shape.triangleup,
     location = location.belowbar, color = color.new(color.green, 0), size = size.small)
plotshape(shortEntry, title = "Short Entry", style = shape.triangledown,
     location = location.abovebar, color = color.new(color.red, 0), size = size.small)

// -----------------------------------------------------------------------------
// Price action - Support / Resistance (swing pivots -> horizontal levels)
// -----------------------------------------------------------------------------
var array<line> resL = array.new_line()
var array<line> supL = array.new_line()

ph = ta.pivothigh(high, srLen, srLen)
pl = ta.pivotlow(low,  srLen, srLen)

if showSR and not na(ph)
    ln = line.new(bar_index - srLen, ph, bar_index, ph,
         color = resCol, width = 1, extend = extend.right)
    array.push(resL, ln)
    if array.size(resL) > srMax
        line.delete(array.shift(resL))

if showSR and not na(pl)
    ln = line.new(bar_index - srLen, pl, bar_index, pl,
         color = supCol, width = 1, extend = extend.right)
    array.push(supL, ln)
    if array.size(supL) > srMax
        line.delete(array.shift(supL))

// -----------------------------------------------------------------------------
// Price action - candlestick patterns
// -----------------------------------------------------------------------------
body   = math.abs(close - open)
upWick = high - math.max(close, open)
dnWick = math.min(close, open) - low
rng    = high - low

bullEngulf = close > open and close[1] < open[1] and close >= open[1] and open <= close[1]
bearEngulf = close < open and close[1] > open[1] and close <= open[1] and open >= close[1]
hammer     = rng > 0 and dnWick > body * pinRatio and upWick < body   // bullish rejection
shootStar  = rng > 0 and upWick > body * pinRatio and dnWick < body   // bearish rejection

plotshape(showPat and bullEngulf, title = "Bull Engulfing", style = shape.labelup,
     location = location.belowbar, color = color.new(color.teal, 0),
     text = "BuEng", textcolor = color.white, size = size.tiny)
plotshape(showPat and bearEngulf, title = "Bear Engulfing", style = shape.labeldown,
     location = location.abovebar, color = color.new(color.maroon, 0),
     text = "BeEng", textcolor = color.white, size = size.tiny)
plotshape(showPat and hammer, title = "Hammer / Pin", style = shape.circle,
     location = location.belowbar, color = color.new(color.green, 0), size = size.tiny)
plotshape(showPat and shootStar, title = "Shooting Star", style = shape.circle,
     location = location.abovebar, color = color.new(color.red, 0), size = size.tiny)

// -----------------------------------------------------------------------------
// Alerts
// -----------------------------------------------------------------------------
alertcondition(longEntry,  title = "st4 Long Entry",  message = "st4 LONG on {{ticker}} {{interval}}")
alertcondition(shortEntry, title = "st4 Short Entry", message = "st4 SHORT on {{ticker}} {{interval}}")
alertcondition(bullEngulf, title = "st4 Bull Engulfing", message = "st4 Bullish Engulfing on {{ticker}} {{interval}}")
alertcondition(bearEngulf, title = "st4 Bear Engulfing", message = "st4 Bearish Engulfing on {{ticker}} {{interval}}")
