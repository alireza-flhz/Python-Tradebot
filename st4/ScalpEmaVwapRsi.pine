//@version=5
// =============================================================================
// Strategy Four (st4) - Scalping: Support/Resistance + FVG (+ EMA/VWAP/RSI engine)
// TradingView Pine Script v5  -  INDICATOR (signals only, no backtest)
//
// Purpose:
//   A multi-timeframe scalping helper for 1m / 5m / 30m charts.
//   It DRAWS on the chart only - it does NOT place orders.
//
// What you SEE on the chart:
//   * IMPORTANT Support / Resistance levels (swing pivots + touch clustering)
//   * IMPORTANT Fair Value Gap (FVG) boxes  (ATR-filtered, filled ones removed)
//   * ENTRY SUGGESTIONS: BUY / SELL arrow + a label with Entry / SL / TP
//   * A subtle bias background              (30m direction)
//
// Entry suggestion logic (this version's focus):
//   LONG  -> 30m bias up  + price reacts at an important SUPPORT (taps it and
//            closes back above) + close above EMA21 + VWAP ok + bullish candle
//            + RSI > 50. SL = just below the support (ATR buffer). TP = nearest
//            important resistance above, else Reward:Risk target.
//   SHORT -> the mirror image at an important resistance.
//   A "+FVG" tag on the label means price is also inside a same-direction FVG.
//
// "Important" filtering:
//   S/R  -> nearby pivots are merged into one level and their TOUCHES counted;
//           only levels touched >= "Min touches" are treated as important.
//   FVG  -> only gaps at least "Min FVG size (xATR)" wide are drawn, and a box
//           is deleted once price trades back through it (mitigated / filled).
//
// The EMA and VWAP LINES are not drawn (chart kept clean). Those values are
// still calculated because the entry engine uses them.
//
// How to run:
//   1. TradingView -> Pine Editor -> paste this file -> Add to chart.
//   2. Set your chart to 1m or 5m. The 30m bias is pulled automatically.
//   3. Right-click a signal -> "Add alert" to get notified live.
// =============================================================================

indicator(
     title            = "st4 - Scalp S/R + FVG",
     shorttitle       = "st4 S/R+FVG",
     overlay          = true,
     max_lines_count  = 200,
     max_boxes_count  = 200,
     max_labels_count = 200)

// -----------------------------------------------------------------------------
// Inputs
// -----------------------------------------------------------------------------
// Bias / entry engine (drives BUY/SELL arrows; lines are hidden)
biasTF     = input.timeframe("30", "Higher-TF Bias",  group = "Bias")
biasEmaLen = input.int(200, "Bias EMA Length", minval = 1, group = "Bias")
emaSlow    = input.int(21,  "EMA Trend filter",     minval = 1, group = "Entry engine")
rsiLen     = input.int(14,  "RSI Length",           minval = 1, group = "Entry engine")
useVwap    = input.bool(true, "Require VWAP alignment", group = "Entry engine")
showSignals= input.bool(true, "Show entry suggestions", group = "Entry engine")

// Entry suggestion (Entry / Stop Loss / Take Profit)
showTrade  = input.bool(true,  "Draw Entry/SL/TP levels", group = "Entry suggestion")
slBufAtr   = input.float(0.5,  "SL buffer beyond level (xATR)", minval = 0.0, step = 0.1, group = "Entry suggestion")
rrTarget   = input.float(2.0,  "Reward:Risk if no opposite level", minval = 0.5, step = 0.5, group = "Entry suggestion")
tradeLen   = input.int(20,     "SL/TP line length (bars)", minval = 1, group = "Entry suggestion")
tradeMax   = input.int(6,      "Max suggestions kept", minval = 1, group = "Entry suggestion")
entryMinT  = input.int(1,      "Min touches for entry level", minval = 1, group = "Entry suggestion")
reqConfirm = input.bool(true,  "Require candle+RSI+VWAP confirm", group = "Entry suggestion")

atrLen     = input.int(14, "ATR Length (for filters)", minval = 1, group = "Importance")

// Support / Resistance
showSR     = input.bool(true, "Show Support/Resistance", group = "Support/Resistance")
srLen      = input.int(15, "S/R Pivot Lookback",  minval = 2, group = "Support/Resistance")
srMinTouch = input.int(2,  "Min touches = important", minval = 1, group = "Support/Resistance")
srTolAtr   = input.float(0.5, "Merge tolerance (xATR)", minval = 0.05, step = 0.05, group = "Support/Resistance")
srMax      = input.int(10, "Max levels tracked", minval = 1, group = "Support/Resistance")
srOnlyImp  = input.bool(true, "Show only important", group = "Support/Resistance")

// Fair Value Gap
showFVG    = input.bool(true, "Show FVG boxes", group = "FVG")
fvgMinAtr  = input.float(0.5, "Min FVG size (xATR)", minval = 0.0, step = 0.05, group = "FVG")
fvgMax     = input.int(12, "Max FVG boxes", minval = 1, group = "FVG")
fvgExtend  = input.int(15, "FVG extend (bars)", minval = 0, group = "FVG")
fvgRemove  = input.bool(true, "Remove filled FVGs", group = "FVG")

resColor   = input.color(color.red,   "Resistance color", group = "Colors")
supColor   = input.color(color.green, "Support color",    group = "Colors")
fvgBullCol = input.color(color.new(color.green, 80), "Bullish FVG", group = "Colors")
fvgBearCol = input.color(color.new(color.red,   80), "Bearish FVG", group = "Colors")

// -----------------------------------------------------------------------------
// Common
// -----------------------------------------------------------------------------
atr = ta.atr(atrLen)

// -----------------------------------------------------------------------------
// Entry engine (calculated, not plotted)
// -----------------------------------------------------------------------------
ema21 = ta.ema(close, emaSlow)
rsi   = ta.rsi(close, rsiLen)
vwap  = ta.vwap(hlc3)

htfBiasEma = request.security(syminfo.tickerid, biasTF, ta.ema(close, biasEmaLen),
     lookahead = barmerge.lookahead_off)
biasUp   = close > htfBiasEma
biasDown = close < htfBiasEma

vwapOkLong  = not useVwap or close > vwap
vwapOkShort = not useVwap or close < vwap
// Entry suggestions are built AFTER the S/R levels below, because a valid entry
// requires price to react at an important support/resistance.

// -----------------------------------------------------------------------------
// Support / Resistance  -  swing pivots clustered into touch-counted levels
// -----------------------------------------------------------------------------
var array<float> lvlPrice = array.new_float()
var array<int>   lvlTouch = array.new_int()
var array<bool>  lvlRes   = array.new_bool()
var array<line>  lvlLine  = array.new_line()
var array<label> lvlLabel = array.new_label()

tol = atr * srTolAtr

// Re-style a level according to its touch count (important -> bold solid line).
f_style(int idx) =>
    price     = array.get(lvlPrice, idx)
    touch     = array.get(lvlTouch, idx)
    isRes     = array.get(lvlRes,   idx)
    important = touch >= srMinTouch
    col       = isRes ? resColor : supColor
    vis       = showSR and (not srOnlyImp or important)
    ln = array.get(lvlLine,  idx)
    lb = array.get(lvlLabel, idx)
    line.set_y1(ln, price)
    line.set_y2(ln, price)
    line.set_color(ln, vis ? col : color.new(col, 100))
    line.set_width(ln, important ? 2 : 1)
    line.set_style(ln, important ? line.style_solid : line.style_dotted)
    label.set_xy(lb, bar_index, price)
    label.set_text(lb, important ? str.tostring(touch) + "x" : "")
    label.set_color(lb, color.new(col, 70))
    label.set_textcolor(lb, (vis and important) ? color.white : color.new(color.white, 100))

// Add a fresh pivot, or merge it into a nearby existing level (counts a touch).
f_addOrMerge(float p, bool isRes) =>
    mergedIdx = -1
    sz = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if mergedIdx == -1 and array.get(lvlRes, i) == isRes and math.abs(array.get(lvlPrice, i) - p) <= tol
                mergedIdx := i
    if mergedIdx == -1
        col = isRes ? resColor : supColor
        ln = line.new(bar_index - srLen, p, bar_index, p,
             color = color.new(col, 100), width = 1, extend = extend.right)
        lb = label.new(bar_index, p, "",
             style = isRes ? label.style_label_down : label.style_label_up,
             size = size.tiny, color = color.new(color.gray, 100),
             textcolor = color.new(color.white, 100))
        array.push(lvlPrice, p)
        array.push(lvlTouch, 1)
        array.push(lvlRes,   isRes)
        array.push(lvlLine,  ln)
        array.push(lvlLabel, lb)
        f_style(array.size(lvlPrice) - 1)
    else
        array.set(lvlPrice, mergedIdx, (array.get(lvlPrice, mergedIdx) + p) / 2.0)
        array.set(lvlTouch, mergedIdx, array.get(lvlTouch, mergedIdx) + 1)
        f_style(mergedIdx)
    // Cap: drop the weakest (fewest touches) level when over the limit.
    if array.size(lvlPrice) > srMax
        minIdx = 0
        minT   = array.get(lvlTouch, 0)
        for i = 1 to array.size(lvlPrice) - 1
            if array.get(lvlTouch, i) < minT
                minT   := array.get(lvlTouch, i)
                minIdx := i
        line.delete(array.get(lvlLine,  minIdx))
        label.delete(array.get(lvlLabel, minIdx))
        array.remove(lvlPrice, minIdx)
        array.remove(lvlTouch, minIdx)
        array.remove(lvlRes,   minIdx)
        array.remove(lvlLine,  minIdx)
        array.remove(lvlLabel, minIdx)

ph = ta.pivothigh(high, srLen, srLen)
pl = ta.pivotlow(low,  srLen, srLen)
if showSR and not na(ph)
    f_addOrMerge(ph, true)
if showSR and not na(pl)
    f_addOrMerge(pl, false)

// -----------------------------------------------------------------------------
// Fair Value Gap (FVG)  -  ATR-filtered, filled boxes removed
// -----------------------------------------------------------------------------
var array<box>   fvgBoxes = array.new_box()
var array<float> fvgTop   = array.new_float()
var array<float> fvgBot   = array.new_float()
var array<bool>  fvgBull  = array.new_bool()

minSize = fvgMinAtr * atr
bullFVG = (low > high[2])  and (low - high[2] >= minSize)   // important bullish gap
bearFVG = (high < low[2])  and (low[2] - high >= minSize)   // important bearish gap

if showFVG and bullFVG
    bx = box.new(bar_index - 2, low, bar_index + fvgExtend, high[2],
         border_color = na, bgcolor = fvgBullCol)
    array.push(fvgBoxes, bx)
    array.push(fvgTop, low)
    array.push(fvgBot, high[2])
    array.push(fvgBull, true)

if showFVG and bearFVG
    bx = box.new(bar_index - 2, low[2], bar_index + fvgExtend, high,
         border_color = na, bgcolor = fvgBearCol)
    array.push(fvgBoxes, bx)
    array.push(fvgTop, low[2])
    array.push(fvgBot, high)
    array.push(fvgBull, false)

// Remove FVGs that price has traded back through (mitigated / filled).
if fvgRemove and array.size(fvgBoxes) > 0
    i = array.size(fvgBoxes) - 1
    while i >= 0
        filled = array.get(fvgBull, i) ? (low <= array.get(fvgBot, i)) : (high >= array.get(fvgTop, i))
        if filled
            box.delete(array.get(fvgBoxes, i))
            array.remove(fvgBoxes, i)
            array.remove(fvgTop, i)
            array.remove(fvgBot, i)
            array.remove(fvgBull, i)
        i := i - 1

// Cap: drop the oldest box when over the limit.
if array.size(fvgBoxes) > fvgMax
    box.delete(array.shift(fvgBoxes))
    array.shift(fvgTop)
    array.shift(fvgBot)
    array.shift(fvgBull)

// -----------------------------------------------------------------------------
// Entry suggestion engine  -  react at an important level, in the bias direction
// -----------------------------------------------------------------------------
// Nearest IMPORTANT support that price just tapped and closed back above.
f_hitSupport() =>
    best = float(na)
    sz = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if not array.get(lvlRes, i) and array.get(lvlTouch, i) >= entryMinT
                lv = array.get(lvlPrice, i)
                if low <= lv + tol and close > lv and (na(best) or lv > best)
                    best := lv
    best

// Nearest resistance that price just tapped and closed back below.
f_hitResistance() =>
    best = float(na)
    sz = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(lvlRes, i) and array.get(lvlTouch, i) >= entryMinT
                lv = array.get(lvlPrice, i)
                if high >= lv - tol and close < lv and (na(best) or lv < best)
                    best := lv
    best

// Nearest important resistance above a price (used as Take Profit for longs).
f_nearestResAbove(float p) =>
    best = float(na)
    sz = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(lvlRes, i) and array.get(lvlTouch, i) >= srMinTouch
                lv = array.get(lvlPrice, i)
                if lv > p and (na(best) or lv < best)
                    best := lv
    best

// Nearest important support below a price (used as Take Profit for shorts).
f_nearestSupBelow(float p) =>
    best = float(na)
    sz = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if not array.get(lvlRes, i) and array.get(lvlTouch, i) >= srMinTouch
                lv = array.get(lvlPrice, i)
                if lv < p and (na(best) or lv > best)
                    best := lv
    best

// Is price currently inside an active FVG of the given direction? (confluence)
f_inFVG(bool bull) =>
    hit = false
    sz = array.size(fvgBoxes)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(fvgBull, i) == bull and close <= array.get(fvgTop, i) and close >= array.get(fvgBot, i)
                hit := true
    hit

supHit = f_hitSupport()
resHit = f_hitResistance()

longConf  = (not reqConfirm) or (close > ema21 and vwapOkLong  and close > open and rsi > 50)
shortConf = (not reqConfirm) or (close < ema21 and vwapOkShort and close < open and rsi < 50)
longRaw  = biasUp   and not na(supHit) and longConf
shortRaw = biasDown and not na(resHit) and shortConf
longEntry  = showSignals and longRaw  and not longRaw[1]
shortEntry = showSignals and shortRaw and not shortRaw[1]

// Trade-level drawings (Entry / SL / TP), kept in arrays with a cap.
var array<label> trLbl = array.new_label()
var array<line>  trSL  = array.new_line()
var array<line>  trTP  = array.new_line()

f_pushTrade(bool isLong, float e, float sl, float tp) =>
    col  = isLong ? color.green : color.red
    conf = f_inFVG(isLong) ? "  +FVG" : ""
    head = (isLong ? "LONG" : "SHORT") + conf
    txt  = head + "\nE  " + str.tostring(e, format.mintick) + "\nSL " + str.tostring(sl, format.mintick) + "\nTP " + str.tostring(tp, format.mintick)
    lb = label.new(bar_index, e, txt,
         style = isLong ? label.style_label_up : label.style_label_down,
         color = color.new(col, 15), textcolor = color.white, size = size.small)
    lnSL = line.new(bar_index, sl, bar_index + tradeLen, sl,
         color = color.new(color.red,   0), width = 1, style = line.style_dashed)
    lnTP = line.new(bar_index, tp, bar_index + tradeLen, tp,
         color = color.new(color.green, 0), width = 1, style = line.style_dashed)
    array.push(trLbl, lb)
    array.push(trSL,  lnSL)
    array.push(trTP,  lnTP)
    if array.size(trLbl) > tradeMax
        label.delete(array.shift(trLbl))
        line.delete(array.shift(trSL))
        line.delete(array.shift(trTP))

if showTrade and longEntry
    e  = close
    sl = supHit - atr * slBufAtr
    r  = f_nearestResAbove(e)
    tp = not na(r) ? r : e + (e - sl) * rrTarget
    f_pushTrade(true, e, sl, tp)

if showTrade and shortEntry
    e  = close
    sl = resHit + atr * slBufAtr
    s  = f_nearestSupBelow(e)
    tp = not na(s) ? s : e - (sl - e) * rrTarget
    f_pushTrade(false, e, sl, tp)

// -----------------------------------------------------------------------------
// Signals & bias background
// -----------------------------------------------------------------------------
plotshape(longEntry,  title = "Long Entry",  style = shape.triangleup,
     location = location.belowbar, color = color.new(color.green, 0),
     size = size.small, text = "BUY")
plotshape(shortEntry, title = "Short Entry", style = shape.triangledown,
     location = location.abovebar, color = color.new(color.red, 0),
     size = size.small, text = "SELL")

bgcolor(biasUp   ? color.new(color.green, 94) : na, title = "Bias Up")
bgcolor(biasDown ? color.new(color.red,   94) : na, title = "Bias Down")

// -----------------------------------------------------------------------------
// Alerts
// -----------------------------------------------------------------------------
alertcondition(longEntry,  title = "st4 Long Entry",  message = "st4 LONG entry on {{ticker}} {{interval}} - see chart for SL/TP")
alertcondition(shortEntry, title = "st4 Short Entry", message = "st4 SHORT entry on {{ticker}} {{interval}} - see chart for SL/TP")
alertcondition(bullFVG,    title = "st4 Bullish FVG", message = "st4 Important Bullish FVG on {{ticker}} {{interval}}")
alertcondition(bearFVG,    title = "st4 Bearish FVG", message = "st4 Important Bearish FVG on {{ticker}} {{interval}}")
